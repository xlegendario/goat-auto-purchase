{
  "manifest_version": 3,
  "name": "GOAT Auto Purchase Runner",
  "version": "1.0.0",
  "description": "Runs GOAT purchase tasks from backend",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://goat-auto-purchase.onrender.com/*",
    "https://www.goat.com/*",
    "https://goat.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.goat.com/*", "https://goat.com/*"],
      "js": ["content-script.js"]
    }
  ]
}
